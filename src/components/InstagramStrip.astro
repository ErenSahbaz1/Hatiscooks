---
import { site } from '../data/site';

const photos = [
  { src: '/meze.jpg', alt: 'Beet meze on whipped yogurt, plated by Hati' },
  { src: '/shot1.jpg', alt: 'Heart-shaped glass with fresh gingershot' },
  { src: '/granola3.jpg', alt: 'Homemade chocolate granola' },
  { src: '/hatis.jpg', alt: 'Hati cooking in the kitchen' },
];
---

<section class="section">
  <div class="container">
    <span class="kicker">Instagram</span>
    <h2>Fresh from <a class="ig-handle" href={site.instagram} rel="noopener">@{site.name}</a></h2>
  </div>
  <!-- photo strip breaks out of the main column for a full-bleed feel -->
  <div class="container container--wide">
    <ul class="ig-grid">
      {photos.map((photo) => (
        <li>
          <a href={site.instagram} rel="noopener" aria-label={`See more on Instagram, @${site.name}`}>
            <img class="ig-photo" src={photo.src} alt={photo.alt} width="600" height="600" loading="lazy" />
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .ig-handle {
    color: var(--color-primary-dark);
  }

  .ig-grid {
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }

  .ig-photo {
    aspect-ratio: 1 / 1;
    width: 100%;
    object-fit: cover;
    border-radius: var(--radius-img);
    transition: transform 200ms ease-out;
  }

  .ig-grid a:hover .ig-photo {
    transform: scale(1.02);
  }

  @media (min-width: 768px) {
    .ig-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-4);
    }
  }
</style>
