---
import BaseLayout from '../layouts/BaseLayout.astro';

// CSS-only confetti: a fixed set of pieces with varied positions/delays.
const confetti = Array.from({ length: 18 }, (_, i) => ({
  left: `${(i * 53) % 100}%`,
  delay: `${(i % 9) * 0.35}s`,
  duration: `${2.6 + (i % 5) * 0.5}s`,
}));

// Edit these freely — plain text, shows as pink pills.
const roles = [
  'The best hala sukurlerolsunamk',
  'The best MENTOR',
  'The best CHEF AMK LUTFEN BANA GUZEL YEMEKLER YAP',
  'Mecidiyeköy serserisi',
  "Marmaray'da klarnet çalan çocuk",
];

// Memories: drop photos in /public and add a line here — add/remove freely.
// caption is optional (shows under the photo, polaroid-style).
const memories: { src: string; alt: string; caption?: string }[] = [
  { src: '/memory1.jpg', alt: 'Memory with Hati', caption: 'EN güçlümüz' },
  { src: '/memory2.jpg', alt: 'Memory with Hati', caption: 'Efeyle' },
  { src: '/memory3.jpg', alt: 'Memory with Hati', caption: '2 güzel' },
  { src: '/memory4.jpg', alt: 'Memory with Hati', caption: 'My teacher' },
  { src: '/memory5.jpg', alt: 'Memory with Hati', caption: 'My coach' },
  { src: '/memory6.jpg', alt: 'Memory with Hati', caption: 'My coach, yaninda da kadir' },
  { src: '/memory7.jpg', alt: 'Memory with Hati', caption: 'Halam ve resmi' },
  { src: '/memory8.jpg', alt: 'Memory with Hati', caption: 'Hatiscooks ve halam' },
];

// Things she always says — fill these in.
const quotes = [
  'AAAAAAAAAAAABI NETWORK YAPIN NETWORK!!!',
  'hm',
  'PATLATMA',
  'DUMAN ABIIIIIIIIIIIIIIII',
];
---

<BaseLayout
  title="Happy birthday! — hatiscooks"
  description="A little surprise for the chef behind hatiscooks."
>
  <!-- Curtain reveal: one big button so tap/click/Enter all open it. -->
  <button class="curtains" type="button" aria-label="Open the curtains to see your surprise">
    <span class="curtain-panel curtain-left" aria-hidden="true"></span>
    <span class="curtain-panel curtain-right" aria-hidden="true"></span>
    <span class="curtain-text">
      <span class="curtain-title">This is for you, Hatis <span class="bday-heart">♥</span></span>
      <span class="curtain-hint">tap to open</span>
    </span>
  </button>
  <noscript>
    <style>
      .curtains { display: none; }
    </style>
  </noscript>

  <section class="section bday">
    <div class="confetti" aria-hidden="true">
      {confetti.map((c, i) => (
        <span
          class={`piece piece-${i % 3}`}
          style={`left: ${c.left}; animation-delay: ${c.delay}; animation-duration: ${c.duration};`}
        ></span>
      ))}
    </div>
    <div class="container bday-inner">
      <img class="bday-logo" src="/logo.png" alt="hatiscooks" width="700" height="479" />
      <span class="kicker">Surprise!</span>
      <h1>Happy birthday, Hatissss <span aria-hidden="true">🎂</span></h1>
      <p>
        This whole website is your present — every page, every pink pixel.
        Now go fill it with your food and make it yours. 
      </p>
     <p> Seni seviyorum halam <span class="bday-heart">♥</span></p>
      <p class="roles-lead">You are…</p>
      <ul class="roles">
        {roles.map((role) => (
          <li class="role-pill">{role}</li>
        ))}
      </ul>

      {memories.length > 0 && (
        <>
          <p class="roles-lead">Some memories…</p>
          <ul class="memories">
            {memories.map((m) => (
              <li class="memory">
                <figure>
                  <img src={m.src} alt={m.alt} width="600" height="600" loading="lazy" />
                  {m.caption && <figcaption>{m.caption}</figcaption>}
                </figure>
              </li>
            ))}
          </ul>
        </>
      )}

      <ul class="quotes">
        {quotes.map((quote) => (
          <li class="quote-card">
            <blockquote><p>“{quote}”</p></blockquote>
            <p class="quote-by">— Hatis probably right now, hm</p>
          </li>
        ))}
      </ul>

      <p class="bday-sign">Made with <span class="bday-heart" aria-hidden="true">♥</span><span class="sr-only">love</span> by Eren Doesn'tcooks</p>
      <a class="btn" href="/">See your website</a>
    </div>
  </section>
</BaseLayout>

<script>
  const curtains = document.querySelector<HTMLButtonElement>('.curtains');
  curtains?.addEventListener(
    'click',
    () => {
      curtains.classList.add('is-open');
      curtains.style.pointerEvents = 'none';
      // remove from the DOM once the slide finishes (or instantly with reduced motion)
      const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) curtains.remove();
      else curtains.addEventListener('transitionend', () => curtains.remove(), { once: true });
    },
    { once: true },
  );
</script>

<style>
  /* ===== Curtain reveal ===== */
  .curtains {
    position: fixed;
    inset: 0;
    z-index: 100;
    border: none;
    background: none;
    padding: 0;
    cursor: pointer;
    display: grid;
    place-items: center;
  }

  .curtain-panel {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 51%; /* tiny overlap so no seam shows in the middle */
    /* velvet folds from the two brand pinks */
    background: repeating-linear-gradient(
      90deg,
      var(--color-primary) 0 36px,
      var(--color-primary-dark) 36px 72px
    );
    transition: transform 1400ms ease-in-out;
  }

  .curtain-left { left: 0; }
  .curtain-right { right: 0; }

  .curtains.is-open .curtain-left { transform: translateX(-101%); }
  .curtains.is-open .curtain-right { transform: translateX(101%); }

  .curtain-text {
    position: relative;
    display: grid;
    gap: var(--space-3);
    padding: var(--space-5);
    text-align: center;
    color: var(--color-surface);
    transition: opacity 400ms ease-out;
  }

  .curtains.is-open .curtain-text {
    opacity: 0;
  }

  .curtain-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.8rem;
    text-wrap: balance;
  }

  .curtain-title .bday-heart {
    color: var(--color-surface);
  }

  .curtain-hint {
    font-size: 1rem;
    opacity: 0.85;
    animation: hint-pulse 1.6s ease-in-out infinite;
  }

  @keyframes hint-pulse {
    50% { opacity: 0.45; }
  }

  @media (min-width: 768px) {
    .curtain-title { font-size: 2.6rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .curtain-panel,
    .curtain-text {
      transition: none;
    }
  }

  /* ===== Page ===== */
  .bday {
    position: relative;
    overflow: hidden;
    min-height: 70vh;
    display: grid;
    align-items: center;
  }

  .bday-inner {
    text-align: center;
    max-width: 40rem;
  }

  /* low-res source — keep small so the soft edges don't show */
  .bday-logo {
    width: 160px;
    height: auto;
    margin: 0 auto var(--space-4);
  }

  .bday-inner p {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .roles-lead {
    margin-top: var(--space-6);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
  }

  .roles {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
  }

  .role-pill {
    padding: var(--space-1) var(--space-4);
    background: var(--color-soft);
    border-radius: var(--radius-pill);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .memories {
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-5);
  }

  /* polaroid look: white frame, caption below, alternating tilt */
  .memory figure {
    margin: 0;
    background: var(--color-surface);
    padding: var(--space-3) var(--space-3) var(--space-4);
    border-radius: 6px;
    box-shadow: var(--shadow-soft);
    transform: rotate(-2deg);
    transition: transform 200ms ease-out;
  }

  .memory:nth-child(even) figure {
    transform: rotate(2deg);
  }

  .memory figure:hover {
    transform: rotate(0deg) scale(1.03);
  }

  .memory img {
    width: 180px;
    height: 180px;
    object-fit: cover;
    border-radius: 4px;
  }

  .memory figcaption {
    margin-top: var(--space-2);
    max-width: 180px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .quotes {
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-3);
    text-align: left;
  }

  .quote-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-4) var(--space-5);
  }

  .quote-card blockquote {
    margin: 0;
    font-style: italic;
  }

  .quote-by {
    margin-top: var(--space-2);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .bday-sign {
    margin-top: var(--space-6);
    font-family: var(--font-heading);
    font-weight: 600;
  }

  /* the one allowed pop-red accent on this screen */
  .bday-heart {
    color: var(--color-pop);
  }

  .bday-inner .btn {
    margin-top: var(--space-6);
  }

  .confetti {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .piece {
    position: absolute;
    top: -24px;
    width: 10px;
    height: 14px;
    border-radius: 3px;
    animation-name: confetti-fall;
    animation-timing-function: ease-in;
    animation-iteration-count: infinite;
  }

  .piece-0 { background: var(--color-primary); }
  .piece-1 { background: var(--color-soft); }
  .piece-2 { background: var(--color-primary-dark); }

  @keyframes confetti-fall {
    to {
      transform: translateY(110vh) rotate(540deg);
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
  }
</style>
